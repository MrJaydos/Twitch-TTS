# ─────────────────────────────────────────────────────────────
# Twitch TTS — environment configuration
# Copy to .env for local dev. In Coolify, set these as env vars.
# ─────────────────────────────────────────────────────────────

# Public base URL the app is served from (no trailing slash).
# Used to build the OAuth redirect and the overlay URL shown in the dashboard.
# Local dev: http://localhost:3000
PUBLIC_URL=http://localhost:3000

# Port the app listens on inside the container.
PORT=3000

# ── Twitch application (https://dev.twitch.tv/console/apps) ──
# OAuth Redirect URL registered on the Twitch app MUST equal:
#   <PUBLIC_URL>/auth/twitch/callback
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Secret used to sign the session cookie. Generate a long random string:
#   openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ── Database ──
# REQUIRED. Password for the bundled Postgres. Both the postgres service and
# the app use it; the app derives DATABASE_URL from it automatically in Docker.
POSTGRES_PASSWORD=change_me_to_a_strong_password

# Only needed when running the app WITHOUT Docker (npm run dev). In Docker this
# is derived from POSTGRES_* automatically, so you can leave it unset there.
DATABASE_URL=postgresql://tts:change_me_to_a_strong_password@localhost:5432/tts?schema=public

# ── Piper TTS HTTP server ──
# Internal compose address of the piper service.
PIPER_URL=http://piper:5000

# Default voice (must be a model present in the piper voices volume).
DEFAULT_VOICE=en_US-amy-medium

# Comma-separated list of piper voices to auto-download on first boot.
# See https://huggingface.co/rhasspy/piper-voices
PIPER_VOICES=en_US-amy-medium,en_US-ryan-high,en_GB-alba-medium

# Where generated WAVs are cached inside the app container (mounted volume).
AUDIO_CACHE_DIR=/data/audio-cache

# Max age (seconds) for cached audio before GC removes it.
AUDIO_TTL_SECONDS=900

# Set to "true" to allow overlay tokens created before login (dev only).
NODE_ENV=development
