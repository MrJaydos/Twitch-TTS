// Prisma schema for Twitch TTS.
// Postgres in production/compose; see DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  twitchId     String    @unique
  login        String
  displayName  String
  // Secret embedded in the OBS overlay URL. Rotatable from the dashboard.
  overlayToken String    @unique @default(cuid())
  createdAt    DateTime  @default(now())
  settings     Settings?
  chatterVoices ChatterVoice[]
}

// Per-chatter voice assignment for a given streamer (overlay owner). Populated
// lazily when `uniqueVoices` is on; `locked` marks a voice the chatter chose
// explicitly (e.g. via a future `!voice` command) so auto-assignment leaves it.
model ChatterVoice {
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  // Chatter's Twitch login (lowercase).
  login     String
  voice     String
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([ownerId, login])
}

model Settings {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Which Twitch channel's chat to read (lowercase login, no leading #).
  channel String  @default("")
  enabled Boolean @default(true)

  // Trigger: "all" reads every message; "prefix" only messages starting with `prefix`.
  triggerMode String @default("all")
  prefix      String @default("!tts")

  // Role gate: "everyone" | "subs" | "vips" | "mods".
  roleGate String @default("everyone")

  // Voice + playback.
  voice  String @default("en_US-amy-medium")
  rate   Float  @default(1.0)
  volume Float  @default(1.0)

  // When true, each chatter is deterministically assigned a voice from the
  // configured pool (PIPER_VOICES) instead of everyone sharing `voice`.
  uniqueVoices Boolean @default(false)

  // When true (and uniqueVoices is on), chatters can pick their own voice with
  // the `!voice` chat command. Turn off to disable the command/bot in chat.
  voiceCommandEnabled Boolean @default(true)

  // Content shaping.
  maxLength    Int     @default(300)
  readUsername Boolean @default(false)
  stripUrls    Boolean @default(true)
  stripEmotes  Boolean @default(true)

  // Rate limiting.
  cooldownSeconds Int @default(0)

  // Filtering. Lists are newline/comma separated to stay DB-portable.
  ignoreList    String @default("")
  blocklist     String @default("")
  blocklistMode String @default("skip") // "skip" | "censor"

  // Overlay presentation.
  captionsEnabled Boolean @default(true)

  updatedAt DateTime @updatedAt
}
